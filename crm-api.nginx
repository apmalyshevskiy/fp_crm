# FUSIONPOS CRM API + статика
#
# Путь: /etc/nginx/sites-available/crm-api
# После замены: sudo nginx -t && sudo systemctl reload nginx
#
# Поменяйте версию PHP в fastcgi_pass, если у вас не 8.3.

server {
    listen 80;
    server_name _;

    root /var/www/crm-api;

    # api.php — это библиотека PHP-CRUD-API, она НЕ должна быть entry point.
    # Запрещаем прямой доступ к ней.
    location = /api.php {
        deny all;
        return 404;
    }

    # Прямой доступ к api.include.php — это наш entry point для PHP-CRUD-API
    location = /api.include.php {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php8.3-fpm.sock;
    }

    # Статика (HTML, CSS, JS, картинки) — отдаётся напрямую если файл существует.
    # Любые «непонятные» URL (/records/, /openapi, /status/, /columns/ и т.п.) — в api.include.php
    location / {
        try_files $uri @api;
    }

    location @api {
        rewrite ^(.*)$ /api.include.php last;
    }

    # Запрет на любые другие .php файлы (мера предосторожности)
    location ~ \.php$ {
        deny all;
        return 404;
    }

    location ~ /\. {
        deny all;
    }
}
